# Local variable values — contain your real project ID, never commit
terraform.tfvars
*.tfvars
!terraform.tfvars.example

# Terraform working directories
.terraform/
.terraform.lock.hcl

# State files (we use remote GCS state, never store locally)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Sensitive outputs exported from `terraform output`
*.json
